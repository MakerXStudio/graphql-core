{
  "name": "@makerx/graphql-core",
  "version": "3.0.0-beta.6",
  "private": false,
  "description": "A set of core GraphQL utilities that MakerX uses to build GraphQL APIs",
  "author": "MakerX",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0"
  },
  "bugs": {
    "url": "https://github.com/MakerXStudio/graphql-core/issues"
  },
  "homepage": "https://github.com/MakerXStudio/graphql-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakerXStudio/graphql-core.git"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "audit": "better-npm-audit audit",
    "format": "prettier --write .",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "build": "run-s build:*",
    "build:0-clean": "rimraf dist coverage",
    "build:1-lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "build:2-check-types": "tsc -p tsconfig.json",
    "build:3-build": "rollup -c --configPlugin typescript",
    "build:4-copy-pkg-json": "tstk copy-package-json -c",
    "build:5-copy-readme": "copyfiles ./README.md ./dist",
    "build:6-check-exports": "attw --pack dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter junit --outputFile test-results.xml"
  },
  "peerDependencies": {
    "@makerx/node-common": ">=1",
    "es-toolkit": ">=1",
    "express": ">=4",
    "graphql": ">=16",
    "graphql-shield": ">=7",
    "graphql-ws": ">=6",
    "ws": ">=8"
  },
  "peerDependenciesMeta": {
    "graphql-shield": {
      "optional": true
    },
    "graphql-ws": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@makerx/eslint-config": "4.2.0",
    "@makerx/node-common": "^1.5.0",
    "@makerx/prettier-config": "2.0.1",
    "@makerx/ts-toolkit": "^5.0.0-beta.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/express": "^5.0.6",
    "@types/node": "25.6.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "4.1.5",
    "better-npm-audit": "^3.11.0",
    "copyfiles": "^2.4.1",
    "es-toolkit": "^1.46.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-shield": "^7.6.5",
    "graphql-ws": "^6.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.2",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.5",
    "ws": "^8.20.0"
  }
}
